<div class="max-w-md mx-auto p-6 bg-gradient-to-br from-white to-gray-100 rounded-2xl shadow-xl border border-gray-200">
  <h3 class="text-xl font-bold mb-4 text-gray-800">
    Ejercicio 10 - Detector de Cambios
  </h3>

  <input
    type="text"
    id="campo10"
    placeholder="Escribe algo..."
    class="border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none p-3 w-full rounded-xl transition duration-300"
  />

  <p 
    id="mensaje10" 
    class="mt-3 text-red-600 font-semibold transition-all duration-300"
  ></p>
</div>

<script>
  const campo = document.getElementById("campo10") as HTMLInputElement | null;
  const mensaje = document.getElementById("mensaje10") as HTMLParagraphElement | null;

  if (campo && mensaje) {
    campo.addEventListener("input", () => {
      if (campo.value.length > 10) {
        mensaje.textContent = "¡Has superado el límite de 10 caracteres!";
        mensaje.classList.add("opacity-100");
      } else {
        mensaje.textContent = "";
        mensaje.classList.remove("opacity-100");
      }
    });
  }
</script>