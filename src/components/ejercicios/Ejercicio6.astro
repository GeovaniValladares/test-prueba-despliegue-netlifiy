<div class="max-w-md mx-auto p-6 bg-gradient-to-br from-white to-gray-100 rounded-2xl shadow-xl border border-gray-200">
  <h3 class="text-xl font-bold mb-6 text-center text-gray-800">
    Ejercicio 6 - Calculadora Básica
  </h3>

  <div class="space-y-4 mb-4">
    <input
      type="number"
      id="num1"
      placeholder="Primer número"
      class="border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none p-3 w-full rounded-xl transition duration-300"
    />

    <input
      type="number"
      id="num2"
      placeholder="Segundo número"
      class="border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none p-3 w-full rounded-xl transition duration-300"
    />
  </div>

  <div class="grid grid-cols-2 gap-3 mb-6">
    <button id="sumar" class="bg-green-600 text-white py-2 rounded-xl hover:bg-green-700 transition">Sumar</button>
    <button id="restar" class="bg-yellow-500 text-white py-2 rounded-xl hover:bg-yellow-600 transition">Restar</button>
    <button id="multiplicar" class="bg-blue-600 text-white py-2 rounded-xl hover:bg-blue-700 transition">Multiplicar</button>
    <button id="dividir" class="bg-red-600 text-white py-2 rounded-xl hover:bg-red-700 transition">Dividir</button>
  </div>

  <div class="p-4 bg-gray-50 border rounded-xl text-center min-h-[60px] flex items-center justify-center">
    <p id="resultado6" class="text-lg font-semibold text-gray-700">
      Resultado: —
    </p>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const num1 = document.getElementById("num1") as HTMLInputElement | null;
    const num2 = document.getElementById("num2") as HTMLInputElement | null;
    const resultado = document.getElementById("resultado6") as HTMLParagraphElement | null;

    const btnSumar = document.getElementById("sumar") as HTMLButtonElement | null;
    const btnRestar = document.getElementById("restar") as HTMLButtonElement | null;
    const btnMultiplicar = document.getElementById("multiplicar") as HTMLButtonElement | null;
    const btnDividir = document.getElementById("dividir") as HTMLButtonElement | null;

    if (!num1 || !num2 || !resultado) return;

    function obtenerNumeros() {
      const n1 = parseFloat(num1!.value);
      const n2 = parseFloat(num2!.value);

      if (isNaN(n1) || isNaN(n2)) {
        resultado!.textContent = "Resultado: Ingresa ambos números";
        return null;
      }

      return { n1, n2 };
    }

    btnSumar?.addEventListener("click", () => {
      const datos = obtenerNumeros();
      if (!datos) return;
      resultado.textContent = "Resultado: " + (datos.n1 + datos.n2);
    });

    btnRestar?.addEventListener("click", () => {
      const datos = obtenerNumeros();
      if (!datos) return;
      resultado.textContent = "Resultado: " + (datos.n1 - datos.n2);
    });

    btnMultiplicar?.addEventListener("click", () => {
      const datos = obtenerNumeros();
      if (!datos) return;
      resultado.textContent = "Resultado: " + (datos.n1 * datos.n2);
    });

    btnDividir?.addEventListener("click", () => {
      const datos = obtenerNumeros();
      if (!datos) return;

      if (datos.n2 === 0) {
        resultado.textContent = "Resultado: No se puede dividir entre cero";
        return;
      }

      resultado.textContent = "Resultado: " + (datos.n1 / datos.n2);
    });
  });
</script>