<div class="max-w-md mx-auto p-6 bg-gradient-to-br from-white to-gray-100 rounded-2xl shadow-xl border border-gray-200">
  <h3 class="text-xl font-bold mb-6 text-gray-800 text-center">
    Ejercicio 20 - Eco en Tiempo Real
  </h3>

  <input
    type="text"
    id="campo20"
    placeholder="Escribe algo..."
    class="border border-gray-300 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none p-3 w-full rounded-xl transition duration-300"
  />

  <div class="mt-5 p-4 bg-indigo-50 rounded-xl border border-indigo-200 min-h-[60px] flex items-center justify-center">
    <p id="eco20" class="font-semibold text-indigo-700 text-lg"></p>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const campo = document.getElementById("campo20") as HTMLInputElement | null;
    const eco = document.getElementById("eco20") as HTMLParagraphElement | null;

    if (!campo || !eco) return;

    campo.addEventListener("input", () => {
      eco.textContent = campo.value;
    });
  });
</script>