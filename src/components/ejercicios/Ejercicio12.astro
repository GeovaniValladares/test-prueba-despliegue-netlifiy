<div class="max-w-md mx-auto p-6 bg-gradient-to-br from-white to-gray-100 rounded-2xl shadow-xl border border-gray-200 text-center">
  <h3 class="text-xl font-bold mb-6 text-gray-800">
    Ejercicio 12 - Cambiador de Texto
  </h3>

  <button 
    id="btn12"
    class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-xl transition duration-300 font-semibold"
  >
    Haz clic aquí
  </button>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("btn12") as HTMLButtonElement | null;
    if (!btn) return;

    let activo = false;

    btn.addEventListener("click", () => {
      activo = !activo;

      if (activo) {
        btn.textContent = "¡Has hecho clic!";
      } else {
        btn.textContent = "Haz clic aquí";
      }
    });
  });
</script>