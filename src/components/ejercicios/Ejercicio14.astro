<div class="max-w-md mx-auto p-6 bg-gradient-to-br from-white to-gray-100 rounded-2xl shadow-xl border border-gray-200">
  <h3 class="text-xl font-bold mb-4 text-gray-800">
    Ejercicio 14 - Detector de Enter
  </h3>

  <input
    type="text"
    id="input14"
    placeholder="Escribe algo y presiona Enter..."
    class="border border-gray-300 focus:border-green-500 focus:ring-2 focus:ring-green-200 outline-none p-3 w-full rounded-xl transition duration-300 mb-4"
  />

  <div class="p-4 bg-green-50 rounded-xl border border-green-200 min-h-[50px]">
    <p id="resultado14" class="font-semibold text-green-700"></p>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const input = document.getElementById("input14") as HTMLInputElement | null;
    const resultado = document.getElementById("resultado14") as HTMLParagraphElement | null;

    if (!input || !resultado) return;

    input.addEventListener("keydown", (event) => {
      if (event.key === "Enter") {
        if (input.value.trim() !== "") {
          resultado.textContent = input.value;
          input.value = ""; // opcional: limpia el campo
        }
      }
    });
  });
</script>